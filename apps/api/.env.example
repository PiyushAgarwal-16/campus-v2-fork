# Campusly V2 API — environment template (SECURITY.md §10).
# Copy to .env and fill in. NEVER commit real secrets.

# Server
NODE_ENV=development
PORT=4000
# Comma-separated list of allowed web origins for CORS
CORS_ORIGINS=http://localhost:3000

# PostgreSQL (DATABASE_SCHEMA.md) — local dev default
DATABASE_URL=postgres://postgres:postgres@localhost:5432/campusly

# Logging
LOG_LEVEL=info

# Authentication (AUTH_SYSTEM.md §3–5). NEVER commit real values.
# Google OAuth client ID (institutional Google sign-in)
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# JWT signing secrets — generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-min-32-chars-use-openssl-rand
JWT_REFRESH_SECRET=change-me-different-min-32-chars-openssl-rand
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
ACCOUNT_DELETION_GRACE_DAYS=14
